# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dragonpay
DRAGONPAY_MERCHANT_ID=
DRAGONPAY_PASSWORD=
DRAGONPAY_API_URL=https://test.dragonpay.ph/api/collect/v1

# Email (optional — skipped with warning if absent)
RESEND_API_KEY=

# AI (optional)
ANTHROPIC_API_KEY=

# Exchange Rate
EXCHANGE_RATE_API_URL=https://open.er-api.com/v6/latest/USD

# Demo Mode
NEXT_PUBLIC_DEMO_MODE=true

# Image storage (optional — defaults to Supabase Storage; set to R2 URL when migrating)
# NEXT_PUBLIC_STORAGE_BASE_URL=https://your-r2-bucket.r2.dev

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3030
